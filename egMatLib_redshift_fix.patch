+    def _insert_above_widget(self, anchor, widgets) -> bool:
+        """Insert widgets directly above anchor inside whatever (possibly
+        nested) layout holds it. Returns False if the layout wasn't found."""
+
+        def find(layout):
+            for i in range(layout.count()):
+                item = layout.itemAt(i)
+                if item.widget() is anchor:
+                    return layout, i
+                if item.layout():
+                    res = find(item.layout())
+                    if res:
+                        return res
+            return None
+
+        parent = anchor.parentWidget()
+        top = parent.layout() if parent else None
+        found = find(top) if top else None
+        if not found:
+            return False
+        layout, idx = found
+        for offset, w in enumerate(widgets):
+            layout.insertWidget(idx + offset, w)
+        return True
+
