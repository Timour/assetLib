+class MaterialItemDelegate(QtWidgets.QStyledItemDelegate):
+    """Paints each material tile as thumbnail + name line + a greyed renderer
+    line beneath it, in both grid (icon on top, text below) and list (icon
+    left, text right) modes. Any failure falls back to the default painting so
+    a bad case degrades to a plain name rather than breaking the view."""
+
+    PAD = 4
+    GAP = 8
+    DIM = QtGui.QColor(150, 150, 150)
+
+    def __init__(self, renderer_role, parent=None):
+        super().__init__(parent)
+        self._renderer_role = renderer_role
+
+    @staticmethod
+    def _to_pixmap(icon):
+        """The model returns a QImage for the thumbnail (0 before it renders);
+        normalise to a QPixmap for painting, or None if there's nothing."""
+        if isinstance(icon, QtGui.QPixmap):
+            return icon if not icon.isNull() else None
+        if isinstance(icon, QtGui.QImage):
+            if icon.isNull():
+                return None
+            return QtGui.QPixmap.fromImage(icon)
+        if isinstance(icon, QtGui.QIcon):
+            pm = icon.pixmap(256, 256)
+            return pm if not pm.isNull() else None
+        return None
+
+    def paint(self, painter, option, index):
+        try:
+            self._paint(painter, option, index)
+        except Exception:
+            super().paint(painter, option, index)
+
+    def _paint(self, painter, option, index):
+        painter.save()
+
+        selected = bool(option.state & QtWidgets.QStyle.StateFlag.State_Selected)
+        alternate = bool(
+            option.features & QtWidgets.QStyleOptionViewItem.ViewItemFeature.Alternate
+        )
+        if selected:
+            painter.fillRect(option.rect, option.palette.highlight())
+        elif alternate:
+            painter.fillRect(option.rect, option.palette.alternateBase())
+
+        rect = option.rect
+        icon = self._to_pixmap(index.data(QtCore.Qt.ItemDataRole.DecorationRole))
+        name = index.data(QtCore.Qt.ItemDataRole.DisplayRole) or ""
+        renderer = index.data(self._renderer_role) or ""
+
+        is_list = False
+        try:
+            is_list = (
+                option.widget.viewMode()
+                == QtWidgets.QListView.ViewMode.ListMode
+            )
+        except Exception:
+            is_list = False
+
+        name_font = QtGui.QFont(option.font)
+        rend_font = QtGui.QFont(option.font)
+        # Sub-line reads as secondary via the grey colour, not by being tiny:
+        # keep it at the name size with a 12pt floor.
+        rend_font.setPointSizeF(max(option.font.pointSizeF(), 12.0))
+        fm_name = QtGui.QFontMetrics(name_font)
+        fm_rend = QtGui.QFontMetrics(rend_font)
+        h_name = fm_name.height()
+        h_rend = fm_rend.height()
+
+        name_color = (
+            option.palette.highlightedText().color()
+            if selected
+            else option.palette.text().color()
+        )
+
+        pad = self.PAD
+        if is_list:
+            icon_side = max(rect.height() - 2 * pad, 1)
+            if icon is not None:
+                scaled = icon.scaled(
+                    icon_side, icon_side,
+                    QtCore.Qt.AspectRatioMode.KeepAspectRatio,
+                    QtCore.Qt.TransformationMode.SmoothTransformation,
+                )
+                iy = rect.top() + (rect.height() - scaled.height()) // 2
+                painter.drawPixmap(rect.left() + pad, iy, scaled)
+            text_left = rect.left() + pad + icon_side + self.GAP
+            text_w = max(rect.right() - text_left - pad, 1)
+            block_h = h_name + (h_rend if renderer else 0)
+            top = rect.top() + (rect.height() - block_h) // 2
+            painter.setFont(name_font)
+            painter.setPen(name_color)
+            painter.drawText(
+                QtCore.QRect(text_left, top, text_w, h_name),
+                QtCore.Qt.AlignmentFlag.AlignLeft
+                | QtCore.Qt.AlignmentFlag.AlignVCenter,
+                fm_name.elidedText(
+                    name, QtCore.Qt.TextElideMode.ElideRight, text_w
+                ),
+            )
+            if renderer:
+                painter.setFont(rend_font)
+                painter.setPen(self.DIM)
+                painter.drawText(
+                    QtCore.QRect(text_left, top + h_name, text_w, h_rend),
+                    QtCore.Qt.AlignmentFlag.AlignLeft
+                    | QtCore.Qt.AlignmentFlag.AlignVCenter,
+                    fm_rend.elidedText(
+                        renderer, QtCore.Qt.TextElideMode.ElideRight, text_w
+                    ),
+                )
+        else:
+            text_w = max(rect.width() - 2 * pad, 1)
+            block_h = h_name + (h_rend if renderer else 0)
+            icon_area = max(rect.height() - block_h - 2 * pad, 1)
+            icon_side = max(min(icon_area, rect.width() - 2 * pad), 1)
+            if icon is not None:
+                scaled = icon.scaled(
+                    icon_side, icon_side,
+                    QtCore.Qt.AspectRatioMode.KeepAspectRatio,
+                    QtCore.Qt.TransformationMode.SmoothTransformation,
+                )
+                ix = rect.left() + (rect.width() - scaled.width()) // 2
+                painter.drawPixmap(ix, rect.top() + pad, scaled)
+            text_top = rect.top() + pad + icon_side
+            painter.setFont(name_font)
+            painter.setPen(name_color)
+            painter.drawText(
+                QtCore.QRect(rect.left() + pad, text_top, text_w, h_name),
+                QtCore.Qt.AlignmentFlag.AlignHCenter
+                | QtCore.Qt.AlignmentFlag.AlignVCenter,
+                fm_name.elidedText(
+                    name, QtCore.Qt.TextElideMode.ElideRight, text_w
+                ),
+            )
+            if renderer:
+                painter.setFont(rend_font)
+                painter.setPen(self.DIM)
+                painter.drawText(
+                    QtCore.QRect(
+                        rect.left() + pad, text_top + h_name, text_w, h_rend
+                    ),
+                    QtCore.Qt.AlignmentFlag.AlignHCenter
+                    | QtCore.Qt.AlignmentFlag.AlignVCenter,
+                    fm_rend.elidedText(
+                        renderer, QtCore.Qt.TextElideMode.ElideRight, text_w
+                    ),
+                )
+
+        painter.restore()
+
