# Initialize parent node variable.
if locals().get("hou_parent") is None:
    hou_parent = hou.node("/stage/gold_edit")

# Code for /stage/gold_edit/gold
hou_node = hou_parent.createNode("subnet", "gold", run_init_scripts=False, load_contents=True, exact_type_name=True)
hou_node.move(hou.Vector2(0, -3.88578e-16))
hou_node.setDebugFlag(False)
hou_node.setDetailLowFlag(False)
